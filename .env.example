# ---- Database ----
# Option A: hosted Postgres (Neon/Supabase/Render) — paste the full connection string.
#   SSL is auto-enabled for these hosts. Takes precedence over the fields below.
DATABASE_URL=
# Optional direct (non-pooled) URL used for migrations/DDL (recommended on Neon).
DIRECT_DATABASE_URL=
DB_SSL=
# Option B: local/discrete connection (used only when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=manatask
DB_PASSWORD=manatask
DB_NAME=manatask
DB_SYNCHRONIZE=true

# ---- API ----
NODE_ENV=development
API_PORT=4000
API_PREFIX=api
WEB_ORIGIN=http://localhost:3000
# Require a 6-digit email OTP before users can access workspace data.
REQUIRE_EMAIL_VERIFICATION=true
LOG_LEVEL=info

# ---- Observability (optional) ----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Redis (optional) — enables durable BullMQ email queue; inline send if empty ----
REDIS_URL=

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=30d

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ---- Mail ----
# Priority: BREVO_API_KEY > RESEND_API_KEY > SMTP_* > console.
# HTTP providers are recommended in production (hosts like Render block SMTP).
# Brevo (brevo.com): free 300/day, verify a single sender email, no domain needed.
BREVO_API_KEY=
# Resend (resend.com): requires a verified domain to email arbitrary recipients.
RESEND_API_KEY=
# SMTP fallback (often blocked on PaaS).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# The verified sender. With Brevo this must be a sender you verified there.
MAIL_FROM=manaTask <no-reply@manatask.local>

# ---- Uploads / Storage ----
# Local disk is used when S3_* is empty. Set S3_* (AWS S3 or S3-compatible: Cloudflare R2, MinIO) for production.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25
# Public base URL of this API (used to build attachment download links).
API_PUBLIC_URL=http://localhost:4000/api
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For Cloudflare R2 / MinIO set the endpoint, e.g. https://<acct>.r2.cloudflarestorage.com
S3_ENDPOINT=

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
